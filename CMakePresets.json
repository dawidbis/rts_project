{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 23,
    "patch": 0
  },

  "configurePresets": [
    {
      "name": "windows-msvc-debug",
      "displayName": "Windows MSVC - Debug",
      "generator": "Visual Studio 17 2022",
      "architecture": {
        "value": "x64",
        "strategy": "set"
      },
      "binaryDir": "${sourceDir}/build/windows-msvc-debug/build",
      "toolchainFile": "${sourceDir}/build/windows-msvc-debug/build/generators/conan_toolchain.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "RTS_ENABLE_ASAN": "OFF",
        "RTS_BUILD_TESTS": "ON",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_POLICY_DEFAULT_CMP0091": "NEW"
      }
    },
    {
      "name": "windows-msvc-release",
      "displayName": "Windows MSVC - Release",
      "inherits": "windows-msvc-debug",
      "binaryDir": "${sourceDir}/build/windows-msvc-release/build",
      "toolchainFile": "${sourceDir}/build/windows-msvc-release/build/generators/conan_toolchain.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "RTS_ENABLE_ASAN": "OFF"
      }
    },
    {
      "name": "windows-msvc-asan",
      "displayName": "Windows MSVC - Debug + ASan (wymaga przebudowy zaleznosci)",
      "inherits": "windows-msvc-debug",
      "binaryDir": "${sourceDir}/build/windows-msvc-asan/build",
      "toolchainFile": "${sourceDir}/build/windows-msvc-asan/build/generators/conan_toolchain.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "RTS_ENABLE_ASAN": "ON"
      }
    },

    {
      "name": "linux-gcc-debug",
      "displayName": "Linux GCC - Debug",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/linux-gcc-debug/build/Debug",
      "toolchainFile": "${sourceDir}/build/linux-gcc-debug/build/Debug/generators/conan_toolchain.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_C_COMPILER": "gcc",
        "CMAKE_CXX_COMPILER": "g++",
        "RTS_ENABLE_ASAN": "ON",
        "RTS_ENABLE_UBSAN": "ON",
        "RTS_ENABLE_CLANG_TIDY": "OFF",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "linux-gcc-release",
      "displayName": "Linux GCC - Release",
      "inherits": "linux-gcc-debug",
      "binaryDir": "${sourceDir}/build/linux-gcc-release/build/Release",
      "toolchainFile": "${sourceDir}/build/linux-gcc-release/build/Release/generators/conan_toolchain.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "RTS_ENABLE_ASAN": "OFF",
        "RTS_ENABLE_UBSAN": "OFF"
      }
    }
  ],

  "buildPresets": [
    {
      "name": "windows-msvc-debug",
      "configurePreset": "windows-msvc-debug",
      "configuration": "Debug"
    },
    {
      "name": "windows-msvc-release",
      "configurePreset": "windows-msvc-release",
      "configuration": "Release"
    },
    {
      "name": "windows-msvc-asan",
      "configurePreset": "windows-msvc-asan",
      "configuration": "Debug"
    },
    {
      "name": "linux-gcc-debug",
      "configurePreset": "linux-gcc-debug"
    },
    {
      "name": "linux-gcc-release",
      "configurePreset": "linux-gcc-release"
    }
  ],

  "testPresets": [
    {
      "name": "windows-msvc-debug",
      "configurePreset": "windows-msvc-debug",
      "configuration": "Debug",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "windows-msvc-release",
      "configurePreset": "windows-msvc-release",
      "configuration": "Release",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "linux-gcc-debug",
      "configurePreset": "linux-gcc-debug",
      "output": { "outputOnFailure": true }
    }
  ]
}